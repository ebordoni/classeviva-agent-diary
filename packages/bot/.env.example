# Token del bot ottenuto da @BotFather su Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Provider AI per il comando /compiti (opzionale)
# Valori: openai | google | anthropic | groq | xai
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=sk-...

# Percorso del file JSON per la cache (default: ./cache.json)
CACHE_DB_PATH=./cache.json
