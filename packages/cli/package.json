{
      "name": "@classeviva/cli",
      "version": "2.0.0",
      "description": "CLI tool per interagire con Classeviva da terminale",
      "main": "./dist/index.js",
      "type": "module",
      "bin": {
            "classeviva": "./dist/index.js",
            "cv": "./dist/index.js"
      },
      "scripts": {
            "build": "tsc",
            "watch": "tsc --watch",
            "clean": "rm -rf dist",
            "dev": "tsx src/index.ts",
            "start": "node dist/index.js"
      },
      "keywords": [
            "classeviva",
            "cli",
            "registro-elettronico",
            "spaggiari",
            "terminal"
      ],
      "author": "ebordoni",
      "license": "MIT",
      "dependencies": {
            "@classeviva/core": "file:../core",
            "chalk": "^5.3.0",
            "cli-table3": "^0.6.3",
            "commander": "^11.1.0",
            "dotenv": "^16.6.1",
            "inquirer": "^9.2.12",
            "ora": "^8.0.1"
      },
      "devDependencies": {
            "@types/inquirer": "^9.0.7",
            "@types/node": "^20.10.0",
            "tsx": "^4.7.0",
            "typescript": "^5.3.3"
      },
      "engines": {
            "node": ">=18.0.0"
      }
}
