{
      "name": "@classeviva/tui",
      "version": "2.0.0",
      "description": "TUI interattiva per Classeviva usando Ink",
      "main": "./dist/index.js",
      "type": "module",
      "bin": {
            "classeviva-tui": "./dist/index.js",
            "cvtui": "./dist/index.js"
      },
      "scripts": {
            "build": "tsc",
            "watch": "tsc --watch",
            "clean": "rm -rf dist",
            "dev": "tsx src/index.tsx",
            "start": "node dist/index.js"
      },
      "keywords": [
            "classeviva",
