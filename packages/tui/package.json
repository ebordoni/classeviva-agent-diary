      "license": "MIT",
      "dependencies": {
            "@classeviva/core": "file:../core",
            "dotenv": "^16.6.1",
            "ink": "^5.2.0",
            "ink-select-input": "^6.0.0",
            "ink-spinner": "^5.0.0",
            "ink-text-input": "^6.0.0",
            "react": "^18.2.0"
      },
      "devDependencies": {
            "@types/node": "^20.10.0",
            "@types/react": "^18.2.0",
            "tsx": "^4.7.0",
            "typescript": "^5.3.3"
      },
      "engines": {
            "node": ">=18.0.0"
      }
